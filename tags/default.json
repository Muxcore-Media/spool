{
  "name": "default",
  "description": "The official MuxCore starter setup. Includes admin UI, REST API, local auth, memory cache, health monitoring, rate limiting, a cron scheduler, and the workflow engine.",
  "version": "1.0.0",
  "modules": [
    {
      "repo": "https://github.com/Muxcore-Media/admin-ui",
      "version": "v1.0.0",
      "required": true
    },
    {
      "repo": "https://github.com/Muxcore-Media/api-rest",
      "version": "v1.0.0",
      "required": true
    },
    {
      "repo": "https://github.com/Muxcore-Media/auth-local",
      "version": "v1.0.0",
      "required": true
    },
    {
      "repo": "https://github.com/Muxcore-Media/cache-memory",
      "version": "v1.0.0",
      "required": true
    },
    {
      "repo": "https://github.com/Muxcore-Media/health-monitor",
      "version": "v1.0.0",
      "required": true
    },
    {
      "repo": "https://github.com/Muxcore-Media/ratelimit-tokenbucket",
      "version": "v1.0.0",
      "required": true
    },
    {
      "repo": "https://github.com/Muxcore-Media/scheduler-cron",
      "version": "v1.0.0",
      "required": false
    },
    {
      "repo": "https://github.com/Muxcore-Media/workflow-engine",
      "version": "v1.0.0",
      "required": false
    }
  ]
}
